{
  "name": "morpho-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "refresh": "tsx src/cli.ts run --json",
    "refresh:excel": "tsx src/cli.ts run --json --excel",
    "refresh:ethereum": "tsx src/cli.ts run --chain=ethereum --json",
